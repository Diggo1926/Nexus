# ─── Autenticacao ─────────────────────────────────────────────────────────────
# Gere uma chave forte: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=sua_chave_secreta_forte_aqui

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origem(s) permitida(s). Separe multiplas com virgula.
# Qualquer *.vercel.app e automaticamente aceito.
# Desenvolvimento:
# CORS_ORIGIN=http://localhost:5173
# Producao:
CORS_ORIGIN=https://nexus-seu-projeto.vercel.app

# ─── Modo Proxy (Railway) ──────────────────────────────────────────────────────
# URL do Cloudflare Tunnel que aponta para o PC local rodando o NEXUS.
# Deixe vazio para modo local (Windows direto).
# Exemplo: NEXUS_LOCAL_URL=https://seu-tunel.trycloudflare.com
NEXUS_LOCAL_URL=

# ─── Wake-on-LAN ──────────────────────────────────────────────────────────────
# MAC Address do PC (ipconfig /all → "Endereco Fisico")
WOL_MAC=00:E0:4C:A1:1E:C0
# Broadcast da sua rede (substitua o ultimo octeto por 255)
WOL_BROADCAST=192.168.100.255

# ─── Apps permitidos (apenas modo local Windows) ────────────────────────────
ALLOWED_APPS=chrome,spotify,notepad,code,explorer

# ─── Servidor ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=5000
